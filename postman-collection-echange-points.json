            "url": {
              "raw": "{{base_url_reward}}/api/recompenses/public/partenaires",
              "host": ["{{base_url_reward}}"],
              "path": ["api", "recompenses", "public", "partenaires"]
            },
            "description": "Liste tous les partenaires avec leurs profils publics"
          },
          "response": []
        },
        {
          "name": "6.3 Offres d'un Partenaire",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url_reward}}/api/recompenses/public/partenaire/{{partner_user_id}}/offres",
              "host": ["{{base_url_reward}}"],
              "path": ["api", "recompenses", "public", "partenaire", "{{partner_user_id}}", "offres"]
            },
            "description": "Liste toutes les offres actives d'un partenaire spécifique"
          },
          "response": []
        }
      ]
    },
    {
      "name": "7. Via API Gateway",
      "item": [
        {
          "name": "7.1 Points via Gateway",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url_gateway}}/api/utilisateurs/{{user_id}}/points",
              "host": ["{{base_url_gateway}}"],
