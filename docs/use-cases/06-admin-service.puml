@startuml admin-service
title Admin Service — Cas d'utilisation
left to right direction
skinparam packageStyle rectangle

actor Administrateur as ADM

rectangle "admin-service" {

  package "Validation comptes" {
    usecase "Voir les comptes à valider" as UC1
    usecase "Consulter le document" as UC2
    usecase "Approuver un compte" as UC3
    usecase "Rejeter un compte" as UC4
  }

  package "Gestion plateforme" {
    usecase "Modérer les actions" as UC5
    usecase "Gérer les catégories" as UC6
    usecase "Gérer les actions fixes" as UC7
    usecase "Gérer les utilisateurs" as UC8
    usecase "Gérer les configurations" as UC9
    usecase "Voir le dashboard" as UC10
  }
}

ADM --> UC1
ADM --> UC2
ADM --> UC3
ADM --> UC4
ADM --> UC5
ADM --> UC6
ADM --> UC7
ADM --> UC8
ADM --> UC9
ADM --> UC10

UC1 ..> UC2 : <<include>>
UC4 ..> UC2 : <<include>>

@enduml
