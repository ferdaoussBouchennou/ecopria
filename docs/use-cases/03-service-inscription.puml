@startuml service-inscription
title Service Inscription — Cas d'utilisation
left to right direction
skinparam packageStyle rectangle

actor Citoyen as CIT
actor Association as ASSO

rectangle "service-inscription" {

  package "Inscriptions" {
    usecase "S'inscrire à une action" as UC1
    usecase "Se désinscrire" as UC2
    usecase "Voir mes inscriptions" as UC3
    usecase "Voir les participants" as UC4
  }

  package "Validation" {
    usecase "Confirmer une inscription" as UC5
    usecase "Refuser une inscription" as UC6
    usecase "Mettre en liste d'attente" as UC7
  }
}

CIT --> UC1
CIT --> UC2
CIT --> UC3
ASSO --> UC4
ASSO --> UC5
ASSO --> UC6

UC1 ..> UC7 : <<extend>>

@enduml
