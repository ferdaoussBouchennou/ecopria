# =============================================================
#  Variables d'environnement pour Ecopria
#  Copiez ce fichier en .env et remplissez les valeurs
# =============================================================

# MySQL - Mot de passe root
MYSQL_ROOT_PASSWORD=root_password_secure_2026

# MySQL - Mot de passe utilisateur ecopria
MYSQL_PASSWORD=ecopria_pass_2026

# Email - Configuration pour le service de notification
EMAIL_USERNAME=votre-email@gmail.com
EMAIL_PASSWORD=votre-mot-de-passe-application

# Note: Pour Gmail, vous devez créer un "mot de passe d'application"
# Allez sur: https://myaccount.google.com/apppasswords
